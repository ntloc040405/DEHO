require('dotenv').config();

const { app } = require('../src/app');
const http = require('http');
const socketIo = require('socket.io');
const mongoose = require('mongoose');

const port = process.env.PORT || 4405;
const server = http.createServer(app);

const io = socketIo(server, {
  cors: {
    origin: '*',
  },
});

io.on('connection', (socket) => {
  console.log('User connected:', socket.id);
  
  // Lấy model Message một cách an toàn
  const Message = mongoose.model('Message');

  // Người dùng (admin hoặc client) join vào room riêng của mình dựa trên ID
  socket.on('join', ({ userId, role }) => {
    // Luôn join vào room userId nếu có, hoặc role nếu không (cho legacy support)
    const roomToJoin = userId || role;
    socket.join(roomToJoin);
    
    // Nếu là admin, join thêm một room chung 'admin_room' để nhận thông báo mới
    if (role === 'admin' || userId === '67e32d8b2157440b136ea729') {
      socket.join('admin_room');
    }
    
    console.log(`User ${socket.id} joined room: ${roomToJoin}`);
  });

  // Khách hàng gửi tin nhắn cho Admin
  socket.on('sendMessage', async ({ senderId, name, avatar, message }) => {
    try {
      if (!senderId || !message) return;

      const msgData = {
        senderId,
        receiverId: '67e32d8b2157440b136ea729', // ID thực tế của Admin từ seed
        senderRole: 'customer',
        name: name || 'Khách hàng',
        avatar: avatar || '/images/avt.png',
        message,
        timestamp: new Date()
      };
      // Lưu vào database
      const newMessage = await Message.create(msgData);
      console.log('📝 Tin nhắn từ khách lưu thành công:', newMessage._id);
      
      // Gửi tới tất cả admin thông qua room chung
      io.to('admin_room').emit('receiveMessage', msgData);
      console.log('📡 Đã phát tin nhắn tới Admin room');
    } catch (err) {
      console.error('Socket error in sendMessage:', err);
    }
  });

  // Admin trả lời khách hàng
  socket.on('replyMessage', async ({ receiverId, message }) => {
    try {
      if (!receiverId || !message) return;

      const msgData = {
        senderId: '67e32d8b2157440b136ea729', // ID thực tế của Admin từ seed
        receiverId,
        senderRole: 'admin',
        name: 'Admin',
        message,
        timestamp: new Date()
      };
      // Lưu vào database
      const newMessage = await Message.create(msgData);
      console.log('📝 Tin nhắn reply từ Admin lưu thành công:', newMessage._id);
      
      // Gửi trực tiếp tới khách hàng dựa trên ID của họ
      io.to(receiverId).emit('receiveMessage', msgData);
      console.log(`📡 Đã phát tin nhắn tới khách hàng: ${receiverId}`);
    } catch (err) {
      console.error('Socket error in replyMessage:', err);
    }
  });
});

server.listen(port, () => {
  console.log(`🚀 Server running on port ${port}`);
});